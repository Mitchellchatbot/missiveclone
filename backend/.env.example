# Copy to .env and edit
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# Postgres connection string. Railway sets this automatically when you attach
# the Postgres plugin. For local dev, point at your own Postgres.
DATABASE_URL=postgres://user:password@localhost:5432/missive_clone

# Force SSL on the Postgres connection (Railway's managed PG and Supabase
# both require it).
# 'true' -> SSL with rejectUnauthorized: false (works for Railway/Render/Heroku/Supabase).
# 'false' -> no SSL (local dev).
# unset -> SSL on if NODE_ENV=production.
DATABASE_SSL=

# Postgres schema all missiveclone tables live in. Defaulting to "missive"
# lets us share a Supabase project with another app (e.g. DelegationDoer)
# without colliding on table names like `users`. The schema is auto-created
# on first boot; queries inside the app stay unqualified and resolve via
# search_path.
DB_SCHEMA=missive

# Frontend origin allowed for CORS / sockets. Leave blank when serving the
# built frontend from this same Express server (single-service deploy).
CLIENT_ORIGIN=

# Optional: encrypt stored IMAP/SMTP passwords (32-byte hex). If empty, plain text.
ENCRYPTION_KEY=

# Set NODE_ENV=production on Railway to enable static frontend serving + SSL.
NODE_ENV=development

# Outbound webhook to DelegationDoer. When both are set, every new
# inbound message ingested fires a POST {WEBHOOK_URL} signed with
# HMAC-SHA256(body, WEBHOOK_SECRET) and the X-Missive-Signature header.
# DD verifies the signature on /api/missive-webhook and pushes a real-
# time event to subscribers (sidebar badge counts, inbox SSE stream).
# Leave both blank in local dev — the call is skipped silently.
#
# Example values (replace host with your DD prod URL):
#   WEBHOOK_URL=https://app.delegationdoerr.com/api/missive-webhook
#   WEBHOOK_SECRET=<random 32-byte hex; same value as MISSIVE_WEBHOOK_SECRET on DD>
WEBHOOK_URL=
WEBHOOK_SECRET=
